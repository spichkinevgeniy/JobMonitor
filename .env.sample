# Runtime mode
APP_ENV="development"

# Telethon (get at https://my.telegram.org)
API_ID="your_api_id"
API_HASH="your_api_hash"
TELEGRAM_PHONE="+79990000000"
TELETHON_LOGIN_MODE="qr"
TELEGRAM_2FA_PASSWORD=""

# aiogram (get from @BotFather)
BOT_TOKEN="your_bot_token"
# Public HTTPS URL for Telegram WebApp buttons
MINI_APP_BASE_URL="https://example.ngrok-free.dev"
# Reserved for future save API integration
MINI_APP_SAVE_API_URL=""
# Local mini-app server bind for `make run-miniapp`
MINI_APP_SERVER_HOST="0.0.0.0"
MINI_APP_SERVER_PORT="8081"

# Path to channels grouping JSON
CHANNELS_MAP_PATH="channels_map.json"

# Mirror channel id (int only)
MIRROR_CHANNEL="-1001234567890"

# Postgres
# For local app run (non-docker): localhost:5433
# For docker app run: values are forced by docker-compose to db:5432
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5433"
POSTGRES_DB="job_monitor"
POSTGRES_USER="job_monitor"
POSTGRES_PASSWORD="change_me"

# LLM
GOOGLE_API_KEY="you_api_key"
GOOGLE_MODEL="gemini-2.5-flash"

# Sentry
SENTRY_DSN=""
SENTRY_ENV="development"
SENTRY_TRACES_SAMPLE_RATE="0.0"

# Logging
LOG_LEVEL="DEBUG"

# Logfire
# `LOGFIRE_TOKEN` is required in production when `LOGFIRE_ENABLED=true`.
# It is needed for Logfire cloud dashboards, including "Basic System Metrics (Logfire)".
LOGFIRE_ENABLED="false"
LOGFIRE_TOKEN=""
LOGFIRE_SERVICE_NAME="jobmonitor"
LOGFIRE_ENV="development"

# Prometheus metrics
METRICS_ENABLED="true"
METRICS_ADDR="0.0.0.0"
METRICS_PORT="8000"
